generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id       String    @id @default(cuid())
  slug     String    @unique
  name     String
  order    Int       @default(0)
  products Product[]
}

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  price       Int
  oldPrice    Int?
  images      String[]
  metal       String?
  stone       String?
  weight      String?
  stock       Int      @default(10)
  isNew       Boolean  @default(false)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  createdAt   DateTime @default(now())

  @@index([categoryId])
}
